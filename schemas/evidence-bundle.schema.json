{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invairiant.org/schemas/evidence-bundle.schema.json",
  "title": "invAIriant Evidence Bundle",
  "description": "The deterministic fact bundle produced by `invairiant collect` and handed to the /invairiant skill as input. Everything here is a candidate pointer gathered mechanically — NOT a finding. The skill applies lenses; only verified, evidence-bound claims become findings. The CLI never judges.",
  "type": "object",
  "required": ["schema", "generated_for", "signals"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "invairiant.evidence-bundle/v1" },
    "notice": { "type": "string" },
    "generated_for": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repo": { "type": "string" },
        "commit": { "type": "string" },
        "branch": { "type": "string" },
        "range": { "type": ["string", "null"] }
      }
    },
    "resolved_scope": {
      "type": "object",
      "description": "The bounded audit scope collect resolved to — the boundary made explicit and auditable. Every downstream field (tree, language stats, signals, generated mass) is computed over this file set only. `bounded: false` occurs solely for the opt-in `repo` scope; every other kind fails closed rather than silently widening.",
      "additionalProperties": true,
      "required": ["kind", "bounded", "files_in_scope"],
      "properties": {
        "kind": { "enum": ["working", "range", "commit", "module", "adr", "repo"] },
        "target": { "type": ["string", "null"], "description": "The pin: the range, commit sha, module path, or ADR path (null for the working tree)." },
        "bounded": { "type": "boolean" },
        "files_in_scope": { "type": "integer", "minimum": 0 },
        "sample_files": { "type": "array", "items": { "type": "string" }, "description": "A capped preview of the in-scope files (not necessarily the full set)." },
        "has_diff": { "type": "boolean", "description": "True for change scopes (working/range/commit); false for snapshot scopes (module/adr/repo)." },
        "docs": { "type": "array", "items": { "type": "string" }, "description": "Scope-supplied documents joined to the canonical set (e.g. the ADR text for an adr scope)." },
        "note": { "type": "string" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "range": { "type": ["string", "null"] },
        "snapshot": { "type": "boolean" },
        "changed_files": { "type": "array", "items": { "type": "object" } },
        "diffstat": { "type": "string" }
      }
    },
    "repo_tree": { "type": "array", "items": { "type": "object" } },
    "language_stats": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "tests_ci": { "type": "object", "additionalProperties": true },
    "config": { "type": ["object", "null"] },
    "canonical_docs": { "type": "array", "items": { "type": "object" } },
    "signals": {
      "type": "object",
      "required": ["model_calls", "shell", "sql", "secrets", "todo"],
      "additionalProperties": { "$ref": "#/$defs/signalList" },
      "properties": {
        "model_calls": { "$ref": "#/$defs/signalList" },
        "shell": { "$ref": "#/$defs/signalList" },
        "sql": { "$ref": "#/$defs/signalList" },
        "secrets": { "$ref": "#/$defs/signalList" },
        "todo": { "$ref": "#/$defs/signalList" }
      }
    },
    "import_boundaries": { "$ref": "#/$defs/signalList" },
    "generated_mass": { "type": "object", "additionalProperties": true },
    "known_rejected": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "signalList": {
      "type": "array",
      "description": "Candidate pointers, not findings.",
      "items": {
        "type": "object",
        "required": ["file"],
        "additionalProperties": true,
        "properties": {
          "file": { "type": "string" },
          "line": { "type": ["integer", "null"] },
          "match": { "type": "string" }
        }
      }
    }
  }
}
